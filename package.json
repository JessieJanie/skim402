{
  "name": "skim-mcp",
  "version": "0.1.5",
  "mcpName": "io.github.JessieJanie/skim402",
  "description": "MCP server for Skim \u2014 clean web reader for AI agents. Pays $0.002 per call in USDC over x402. No signup, no API keys.",
  "type": "module",
  "bin": {
    "skim-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "pnpm build",
    "postinstall": "npm install -g tsx@4.21.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "viem": "^2.21.0",
    "x402-fetch": "^0.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "x402",
    "skim",
    "ai",
    "agent",
    "reader",
    "markdown",
    "web-scraping",
    "claude",
    "cursor"
  ],
  "homepage": "https://skim402.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JessieJanie/skim402.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
